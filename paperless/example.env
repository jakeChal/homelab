# Database password — used by both the db and webserver containers
PAPERLESS_DB_PASSWORD=change-me-strong-db-password

# Secret key for Django — generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string

# URL where Paperless is accessible (used in email links etc.)
PAPERLESS_URL=http://paperless.home

# Admin account created on first startup (remove after first run for security)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me
PAPERLESS_ADMIN_MAIL=admin@example.com

# Match UID/GID to the host user that owns the media/consume directories
# Run: id $USER  to find your values
USERMAP_UID=1000
USERMAP_GID=1000

# Optional: OCR language (default is eng; add more e.g. "eng+fra")
# PAPERLESS_OCR_LANGUAGE=eng

# Optional: timezone
# PAPERLESS_TIME_ZONE=Europe/London
